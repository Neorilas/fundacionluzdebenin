# Sustituye el dominio por el tuyo si cambias de proveedor.
# Caddy obtiene y renueva el certificado SSL automáticamente.

{$DOMAIN} {

    # API pública, panel admin e imágenes → backend
    handle /api/* {
        reverse_proxy backend:3001
    }
    handle /admin/* {
        reverse_proxy backend:3001
    }
    handle /uploads/* {
        reverse_proxy backend:3001
    }

    # Todo lo demás → frontend estático (Nginx)
    handle {
        reverse_proxy frontend:80
    }

    # Logs
    log {
        output file /data/logs/access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# Redirige www → sin www
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}
