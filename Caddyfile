# ─────────────────────────────────────────────────────────────────────────────
# Caddyfile — Proxy inverso + SSL automático (Let's Encrypt)
#
# El dominio se lee de $DOMAIN en .env  →  no toques este archivo para cambiar
# de subdominio a dominio definitivo. Solo cambia DOMAIN en .env y ejecuta:
#   bash scripts/switch-domain.sh
# ─────────────────────────────────────────────────────────────────────────────

{$DOMAIN} {

    # API REST, panel admin e imágenes → backend
    handle /api/* {
        reverse_proxy backend:3001
    }
    handle /admin/* {
        reverse_proxy backend:3001
    }
    handle /uploads/* {
        reverse_proxy backend:3001
    }

    # Web pública → frontend estático (Nginx)
    handle {
        reverse_proxy frontend:80
    }

    # Cabeceras de seguridad básicas
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output file /data/logs/access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# www → sin www (actúa solo cuando DOMAIN es el dominio raíz)
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}
