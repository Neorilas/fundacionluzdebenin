generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEs     String
  titleFr     String
  descEs      String
  descFr      String
  status      String   @default("active") // active | completed | planned
  featured    Boolean  @default(false)
  images      String   @default("[]") // JSON array of image URLs
  stats       String   @default("{}") // JSON object with stats
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titleEs     String
  titleFr     String
  excerptEs   String
  excerptFr   String
  contentEs   String
  contentFr   String
  coverImage  String    @default("")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PageSection {
  id       String @id @default(cuid())
  page     String
  section  String
  key      String
  valueEs  String @default("")
  valueFr  String @default("")

  @@unique([page, section, key])
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model StripeProduct {
  id              String     @id @default(cuid())
  stripeProductId String?
  stripePriceId   String?    @unique
  nameEs          String
  nameFr          String
  descEs          String     @default("")
  descFr          String     @default("")
  amount          Int                          // céntimos (1000 = 10€)
  interval        String     @default("month") // "month" | "year"
  currency        String     @default("eur")
  active          Boolean    @default(true)
  order           Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  donations       Donation[]
}

model Donation {
  id                    String         @id @default(cuid())
  stripeSessionId       String?        @unique
  stripePaymentIntentId String?        @unique
  stripeSubscriptionId  String?        @unique
  stripeCustomerId      String?
  type                  String                  // "one_time" | "subscription"
  status                String         @default("pending") // pending|completed|failed|canceled
  amount                Int                     // céntimos
  currency              String         @default("eur")
  donorName             String?
  donorEmail            String?
  donorDni              String?                 // para certificado fiscal anual
  stripeProductId       String?
  stripeProduct         StripeProduct? @relation(fields: [stripeProductId], references: [id])
  paidAt                DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}
