generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEs     String
  titleFr     String
  descEs      String
  descFr      String
  status      String   @default("active") // active | completed | planned
  featured    Boolean  @default(false)
  images      String   @default("[]") // JSON array of image URLs
  stats       String   @default("{}") // JSON object with stats
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id           String    @id @default(cuid())
  slug         String    @unique
  titleEs      String
  titleFr      String
  metaTitleEs  String    @default("")
  metaTitleFr  String    @default("")
  excerptEs    String
  excerptFr    String
  contentEs    String
  contentFr    String
  coverImage    String    @default("")
  coverImageAlt String    @default("")
  category      String    @default("")
  tags         String    @default("[]") // JSON array of strings
  focusKeyword String    @default("")
  published    Boolean   @default(false)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model PageSection {
  id       String @id @default(cuid())
  page     String
  section  String
  key      String
  valueEs  String @default("")
  valueFr  String @default("")

  @@unique([page, section, key])
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model Campaign {
  id          String   @id @default(cuid())
  slug        String   @unique
  emoji       String   @default("")
  amountCents Int
  colorScheme String   @default("amber")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Hero
  tagEs       String   @default("")
  tagFr       String   @default("")
  titleEs     String   @default("")
  titleFr     String   @default("")
  taglineEs   String   @default("")
  taglineFr   String   @default("")
  priceLabel  String   @default("")
  periodEs    String   @default("")
  periodFr    String   @default("")
  ctaEs       String   @default("")
  ctaFr       String   @default("")
  fineEs      String   @default("")
  fineFr      String   @default("")

  // Cover items — JSON: [{icon, textEs, textFr}, ...]
  coverItems  String   @default("[]")

  // Project section
  projectTitleEs  String  @default("")
  projectTitleFr  String  @default("")
  projectTextEs   String  @default("")
  projectTextFr   String  @default("")
  projectBadgeEs  String  @default("")
  projectBadgeFr  String  @default("")
  projectLinkEs   String  @default("")
  projectLinkFr   String  @default("")
  projectHref     String  @default("")

  // Extra section (stats | why | empty)
  extraType       String  @default("")
  extraTitleEs    String  @default("")
  extraTitleFr    String  @default("")
  extraItems      String  @default("[]")

  // CTA final
  ctaBottomEs     String  @default("")
  ctaBottomFr     String  @default("")
  ctaBottomNoteEs String  @default("")
  ctaBottomNoteFr String  @default("")

  // Meta SEO
  metaTitleEs     String  @default("")
  metaTitleFr     String  @default("")
  metaDescEs      String  @default("")
  metaDescFr      String  @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SantoLead {
  id                   String   @id @default(cuid())
  email                String
  nombre               String   @default("")
  santoId              Int
  santoNombre          String
  aceptaComunicaciones Boolean  @default(false)
  lang                 String   @default("es")
  createdAt            DateTime @default(now())
}

model Faq {
  id         String   @id @default(cuid())
  questionEs String
  questionFr String
  answerEs   String
  answerFr   String
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StripeProduct {
  id              String     @id @default(cuid())
  stripeProductId String?
  stripePriceId   String?    @unique
  nameEs          String
  nameFr          String
  descEs          String     @default("")
  descFr          String     @default("")
  amount          Int                          // cents (1000 = 10 EUR)
  interval        String     @default("month") // "month" | "year"
  currency        String     @default("eur")
  active          Boolean    @default(true)
  order           Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  donations       Donation[]
}

model Donation {
  id                    String         @id @default(cuid())
  stripeSessionId       String?        @unique
  stripePaymentIntentId String?        @unique
  stripeSubscriptionId  String?        @unique
  stripeCustomerId      String?
  type                  String                  // "one_time" | "subscription"
  status                String         @default("pending") // pending|completed|failed|canceled
  amount                Int                     // cents
  currency              String         @default("eur")
  donorName             String?
  donorEmail            String?
  donorDni              String?                 // para certificado fiscal anual
  animalName            String?                 // nombre del animal apadrinado
  stripeProductId       String?
  stripeProduct         StripeProduct? @relation(fields: [stripeProductId], references: [id])
  paidAt                DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}
